---
/**
 * Sticky CTA mobile — fixé en bas d'écran, visible uniquement sur mobile
 */
import { getHero, getSiteInfo } from '@data/content';

const hero = getHero();
const site = getSiteInfo();
---

<div id="sticky-cta" class="fixed bottom-0 left-0 right-0 z-50 md:hidden bg-white border-t border-neutral-200 px-4 py-3 safe-area-bottom transition-transform duration-300 translate-y-full">
  <button type="button"
     data-cal-link={site.calUrl}
     data-cal-config='{"layout":"month_view"}'
     class="block w-full bg-accent-500 text-primary-950 font-semibold text-center py-3 rounded-lg hover:bg-accent-400 transition-colors min-h-[44px] cursor-pointer">
    {hero.ctaText}
  </button>
</div>

<style>
  .safe-area-bottom {
    padding-bottom: max(0.75rem, env(safe-area-inset-bottom));
  }
</style>

<script>
  const stickyCta = document.getElementById('sticky-cta');
  if (stickyCta) {
    // Apparaît uniquement quand le bouton CTA du Hero n'est plus visible
    const heroCta = document.querySelector('#hero a[href*="calendly"], #hero a.bg-accent-500, section:first-of-type a.bg-accent-500');
    const threshold = heroCta
      ? () => heroCta.getBoundingClientRect().bottom < 0
      : () => window.scrollY > window.innerHeight * 2;

    const show = () => {
      if (threshold()) {
        stickyCta.classList.remove('translate-y-full');
      } else {
        stickyCta.classList.add('translate-y-full');
      }
    };
    window.addEventListener('scroll', show, { passive: true });
    show();
  }
</script>
