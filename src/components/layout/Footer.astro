---
import { getSiteInfo } from '@data/content';

const site = getSiteInfo();
const currentYear = new Date().getFullYear();
---

<footer class="bg-primary-950 text-neutral-100" role="contentinfo">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Col 1 : Identité -->
      <div>
        <p class="font-heading font-bold text-lg text-white mb-3">{site.name}</p>
        <p class="text-neutral-300 text-sm leading-relaxed">
          Coach certifié en prise de parole en public en Île-de-France. Approche unique mêlant coaching et improvisation théâtrale.
        </p>
      </div>

      <!-- Col 2 : Contact -->
      <div>
        <p class="font-heading font-semibold text-white mb-3">Contact</p>
        <ul class="space-y-2 text-sm list-none m-0 p-0" role="list">
          {site.phone && (
            <li>
              <a href={`tel:${site.phone.replace(/\s/g, '')}`} class="text-neutral-300 hover:text-accent-400 transition-colors">
                {site.phone}
              </a>
            </li>
          )}
          {site.email && (
            <li>
              <a href={`mailto:${site.email}`} class="text-neutral-300 hover:text-accent-400 transition-colors">
                {site.email}
              </a>
            </li>
          )}
          <li class="text-neutral-400">
            Île-de-France · Sur rendez-vous
          </li>
        </ul>
      </div>

      <!-- Col 3 : Liens -->
      <div>
        <p class="font-heading font-semibold text-white mb-3">Liens</p>
        <ul class="space-y-2 text-sm list-none m-0 p-0" role="list">
          {site.linkedin && (
            <li>
              <a href={site.linkedin} target="_blank" rel="noopener noreferrer" class="text-neutral-300 hover:text-accent-400 transition-colors" aria-label="Profil LinkedIn d'Angelo Grossi">
                LinkedIn
              </a>
            </li>
          )}
          <li>
            <a href="/mentions-legales" class="text-neutral-300 hover:text-accent-400 transition-colors">
              Mentions légales
            </a>
          </li>
          <li>
            <a href="/politique-confidentialite" class="text-neutral-300 hover:text-accent-400 transition-colors">
              Politique de confidentialité
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Séparation -->
    <div class="border-t border-primary-800 mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-neutral-400 text-xs">
        &copy; {currentYear} {site.name} — Coach prise de parole en public
      </p>
      <a href="https://marcm.fr/" class="text-neutral-500 text-xs hover:text-neutral-300 transition-colors">
        Site réalisé par Marc M. · Création de sites web
      </a>
    </div>
  </div>
</footer>
