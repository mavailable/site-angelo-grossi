---
/**
 * SocialProof — Bande de chiffres clés
 * Fond accent-50 (doré très clair) pour contraste avec le Hero sombre au-dessus
 */
---

<section class="bg-accent-50 py-12 md:py-16" aria-label="Chiffres clés">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
      <div>
        <p class="font-heading font-bold text-3xl md:text-4xl text-accent-700">25 ans</p>
        <p class="text-neutral-700 text-sm mt-2">d'expérience en entreprise<br><span class="text-neutral-500">Siemens, Unify, Atos</span></p>
      </div>
      <div>
        <p class="font-heading font-bold text-3xl md:text-4xl text-accent-700">15 ans</p>
        <p class="text-neutral-700 text-sm mt-2">de pratique de<br>l'improvisation théâtrale</p>
      </div>
      <div>
        <p class="font-heading font-bold text-3xl md:text-4xl text-accent-700">RNCP 7</p>
        <p class="text-neutral-700 text-sm mt-2">Certification coaching<br><span class="text-neutral-500">niveau Master</span></p>
      </div>
    </div>
  </div>
</section>
