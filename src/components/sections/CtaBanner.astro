---
/**
 * CTA Banner — Fond sombre avec accent doré, plus atmosphérique
 */
import Button from '@components/ui/Button.astro';

interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaLink?: string;
}

const {
  title = 'Prêt à transformer votre prise de parole ?',
  subtitle = 'Réservez votre RDV découverte gratuit — 30 minutes, sans engagement.',
  ctaText = 'Je réserve mon RDV découverte',
  ctaLink = '#contact',
} = Astro.props;
---

<section class="relative bg-primary-950 py-16 md:py-20 overflow-hidden" aria-label="Appel à l'action">
  <!-- Warm glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[200px] bg-accent-500 rounded-full blur-[120px] opacity-10" aria-hidden="true"></div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
    <div class="w-10 h-[2px] bg-accent-500 mx-auto mb-8" aria-hidden="true"></div>
    <h2 class="font-heading font-bold text-white text-2xl md:text-3xl mb-4">
      {title}
    </h2>
    <p class="text-neutral-400 mb-8">
      {subtitle}
    </p>
    <Button href={ctaLink} variant="primary" size="lg">
      {ctaText}
    </Button>
  </div>
</section>
