---
/**
 * CTA Banner — Bloc accent entre les sections
 * Fond accent-500 avec texte sombre
 */
import Button from '@components/ui/Button.astro';

interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaLink?: string;
}

const {
  title = 'Prêt à transformer votre prise de parole ?',
  subtitle = 'Réservez votre RDV découverte gratuit — 30 minutes, sans engagement.',
  ctaText = 'Je réserve mon RDV découverte',
  ctaLink = '#contact',
} = Astro.props;
---

<section class="bg-accent-500 py-12 md:py-16" aria-label="Appel à l'action">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
    <h2 class="font-heading font-semibold text-primary-950 text-xl md:text-2xl mb-3">
      {title}
    </h2>
    <p class="text-primary-800 mb-6">
      {subtitle}
    </p>
    <Button href={ctaLink} variant="secondary" size="lg">
      {ctaText}
    </Button>
  </div>
</section>
