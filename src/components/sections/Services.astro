---
/**
 * Services — Editorial layout with stronger typography
 */
import { getServices, getSiteInfo, getSections } from '@data/content';
import SectionEyebrow from '@components/ui/SectionEyebrow.astro';
import Button from '@components/ui/Button.astro';

const services = getServices();
const site = getSiteInfo();
const section = getSections().services;
---

<section id="services" class="bg-white py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Section header — left-aligned, not centered -->
    <div class="max-w-2xl mb-16">
      <SectionEyebrow text={section.eyebrow} />
      <h2 class="font-heading font-bold text-primary-950 text-3xl md:text-4xl leading-tight">
        {section.title}
      </h2>
    </div>

    <!-- Services list — editorial style, not card grid -->
    <div class="space-y-0 divide-y divide-neutral-200">
      {services.map((service, i) => (
        <article class="group py-8 md:py-10 grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-8 items-baseline">
          <div class="md:col-span-1">
            <span class="font-heading font-bold text-accent-500/60 text-2xl">{String(i + 1).padStart(2, '0')}</span>
          </div>
          <div class="md:col-span-4">
            <h3 class="font-heading font-semibold text-primary-950 text-xl md:text-2xl group-hover:text-accent-700 transition-colors">{service.title}</h3>
          </div>
          <div class="md:col-span-7">
            <p class="text-neutral-600 leading-relaxed">{service.description}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-12 pt-8 border-t border-neutral-100">
      <Button dataCalLink={site.calUrl} variant="primary" dataTrack="cta">
        {section.ctaText}
      </Button>
    </div>
  </div>
</section>
