---
/**
 * Services — Fond blanc
 * Layout : grille 2 cols desktop, cards avec icône décorative numérotée
 */
import { getServices } from '@data/content';
import SectionEyebrow from '@components/ui/SectionEyebrow.astro';
import Button from '@components/ui/Button.astro';

const services = getServices();

const serviceIcons = [
  // Micro SVG inline par service
  '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>',
  '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>',
  '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>',
  '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>',
];
---

<section id="services" class="bg-white py-16 md:py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-12">
      <SectionEyebrow text="Ce que je vous propose" />
      <h2 class="font-heading font-semibold text-primary-950 text-2xl md:text-3xl">
        Une approche unique : le ThéâtroCoaching
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      {services.map((service, i) => (
        <article class="bg-neutral-50 rounded-xl p-6 hover:shadow-md transition-shadow border border-neutral-100">
          <div class="flex items-start gap-4">
            <div class="shrink-0 w-10 h-10 bg-accent-100 rounded-lg flex items-center justify-center text-accent-700" set:html={serviceIcons[i] || serviceIcons[0]} />
            <div>
              <h3 class="font-heading font-semibold text-primary-950 text-lg mb-2">{service.title}</h3>
              <p class="text-neutral-600 text-sm leading-relaxed">{service.description}</p>
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="text-center mt-10">
      <Button href="#contact" variant="primary">
        Discutons de vos besoins
      </Button>
    </div>
  </div>
</section>
