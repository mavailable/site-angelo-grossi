---
/**
 * Témoignages — Fond blanc
 * Layout : grille 3 colonnes desktop avec cards à fond primaire très clair
 */
import { getTestimonials } from '@data/content';
import SectionEyebrow from '@components/ui/SectionEyebrow.astro';

const testimonials = getTestimonials();
---

<section id="temoignages" class="bg-white py-16 md:py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-12">
      <SectionEyebrow text="Ils incarnent leur parole" />
      <h2 class="font-heading font-semibold text-primary-950 text-2xl md:text-3xl">
        Des résultats concrets, pas des promesses
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {testimonials.map((t) => (
        <article class="bg-primary-50 rounded-xl p-6 flex flex-col">
          <!-- Guillemet décoratif -->
          <svg class="w-8 h-8 text-accent-400 mb-4 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11h4v10H0z"/>
          </svg>
          <blockquote class="text-neutral-700 text-sm leading-relaxed mb-4 grow">
            {t.quote}
          </blockquote>
          <footer class="border-t border-primary-100 pt-3 mt-auto">
            <p class="font-semibold text-primary-950 text-sm">{t.name}</p>
            <p class="text-neutral-500 text-xs">{t.role}</p>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>
