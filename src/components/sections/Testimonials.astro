---
/**
 * Témoignages — Layout éditorial, premier témoignage mis en avant
 */
import { getTestimonials, getSections } from '@data/content';
import SectionEyebrow from '@components/ui/SectionEyebrow.astro';

const testimonials = getTestimonials();
const section = getSections().testimonials;
const featured = testimonials[0];
const others = testimonials.slice(1);
---

<section id="temoignages" class="bg-white py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="max-w-2xl mb-16">
      <SectionEyebrow text={section.eyebrow} />
      <h2 class="font-heading font-bold text-primary-950 text-3xl md:text-4xl leading-tight">
        {section.title}
      </h2>
    </div>

    {featured && (
      <article class="mb-12 p-8 md:p-12 bg-primary-950 rounded-xl relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-accent-500 rounded-full blur-[80px] opacity-10" aria-hidden="true"></div>
        <div class="relative">
          <svg class="w-10 h-10 text-accent-500/40 mb-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11h4v10H0z"/>
          </svg>
          <blockquote class="text-white text-lg md:text-xl leading-relaxed mb-6 max-w-3xl">
            {featured.quote}
          </blockquote>
          <footer>
            <p class="font-semibold text-accent-300">{featured.name}</p>
            <p class="text-neutral-500 text-sm">{featured.role}</p>
          </footer>
        </div>
      </article>
    )}

    {others.length > 0 && (
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {others.map((t) => (
          <article class="border border-neutral-200 rounded-lg p-6 md:p-8">
            <blockquote class="text-neutral-700 leading-relaxed mb-5">
              {t.quote}
            </blockquote>
            <footer class="flex items-center gap-3">
              <div class="w-8 h-[2px] bg-accent-500/40"></div>
              <div>
                <p class="font-semibold text-primary-950 text-sm">{t.name}</p>
                <p class="text-neutral-500 text-xs">{t.role}</p>
              </div>
            </footer>
          </article>
        ))}
      </div>
    )}
  </div>
</section>
