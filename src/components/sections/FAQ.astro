---
/**
 * FAQ — Accordéon natif, fond blanc, typographie plus forte
 */
import { getFaq, getSections } from '@data/content';
import SectionEyebrow from '@components/ui/SectionEyebrow.astro';

const faqs = getFaq();
const section = getSections().faq;
---

<section id="faq" class="bg-neutral-50 py-20 md:py-28">
  <div class="max-w-3xl mx-auto px-4 sm:px-6">
    <div class="mb-14">
      <SectionEyebrow text={section.eyebrow} />
      <h2 class="font-heading font-bold text-primary-950 text-3xl md:text-4xl leading-tight">
        {section.title}
      </h2>
    </div>

    <div class="space-y-0 divide-y divide-neutral-200">
      {faqs.map((faq, i) => (
        <details class="group" open={i === 0}>
          <summary class="flex items-center justify-between gap-4 py-5 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
            <span class="font-heading font-semibold text-primary-950 group-open:text-accent-700 transition-colors">{faq.question}</span>
            <svg class="w-5 h-5 text-neutral-400 shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="pb-6 pl-0">
            <p class="text-neutral-600 leading-relaxed">{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
