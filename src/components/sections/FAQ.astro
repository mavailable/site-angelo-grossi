---
/**
 * FAQ — Fond primary-50 (très léger)
 * Layout : accordéon natif avec <details>/<summary>, pas de JS
 */
import { getFaq } from '@data/content';
import SectionEyebrow from '@components/ui/SectionEyebrow.astro';

const faqs = getFaq();
---

<section id="faq" class="bg-primary-50 py-16 md:py-24">
  <div class="max-w-3xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-12">
      <SectionEyebrow text="Questions fréquentes" />
      <h2 class="font-heading font-semibold text-primary-950 text-2xl md:text-3xl">
        Vos questions, mes réponses
      </h2>
    </div>

    <div class="space-y-3">
      {faqs.map((faq, i) => (
        <details class="group bg-white rounded-lg border border-primary-100 overflow-hidden" open={i === 0}>
          <summary class="flex items-center justify-between gap-4 px-6 py-4 cursor-pointer hover:bg-primary-50 transition-colors list-none [&::-webkit-details-marker]:hidden">
            <span class="font-semibold text-primary-950 text-sm md:text-base">{faq.question}</span>
            <svg class="w-5 h-5 text-primary-400 shrink-0 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 pb-4">
            <p class="text-neutral-600 text-sm leading-relaxed">{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
