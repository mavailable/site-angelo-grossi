---
/**
 * Hero — Fond sombre primary-950 avec ambiance théâtrale
 * Layout : texte centré sur mobile, asymétrique (texte gauche + photo droite) sur desktop
 */
import { getHero } from '@data/content';
import Button from '@components/ui/Button.astro';

const hero = getHero();
---

<section id="hero" class="relative bg-primary-950 overflow-hidden">
  <!-- Atmospheric background -->
  <div class="absolute inset-0 bg-gradient-to-br from-primary-950 via-primary-900 to-secondary-950" aria-hidden="true"></div>
  <div class="absolute top-0 right-1/4 w-[600px] h-[600px] bg-accent-500 rounded-full blur-[200px] opacity-[0.07]" aria-hidden="true"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-secondary-700 rounded-full blur-[150px] opacity-[0.08]" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-24 md:py-32 lg:py-40">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center">
      <!-- Text content — 7 cols -->
      <div class="lg:col-span-7 text-center lg:text-left">
        <!-- Decorative line -->
        <div class="w-12 h-[2px] bg-accent-500 mb-8 mx-auto lg:mx-0" aria-hidden="true"></div>

        <h1 class="font-heading font-bold text-white text-4xl md:text-5xl lg:text-[3.5rem] leading-[1.1] tracking-tight mb-8">
          {hero.title}
        </h1>

        <div class="border-l-2 border-accent-500/60 pl-5 mb-10">
          <p class="text-neutral-300 text-lg md:text-xl leading-relaxed max-w-lg mx-auto lg:mx-0">
            {hero.subtitle}
          </p>
        </div>

        <div class="flex flex-col sm:flex-row sm:items-center gap-4 justify-center lg:justify-start mb-6">
          <Button href={hero.ctaLink} variant="primary" size="md" dataTrack="cta">
            {hero.ctaText}
          </Button>
          {hero.ctaSecondaryText && (
            <Button href={hero.ctaSecondaryLink} variant="outline" size="md" class="border-white/30 text-white hover:bg-white/10 hover:border-white/60">
              {hero.ctaSecondaryText}
            </Button>
          )}
        </div>

        {hero.reassurance && (
          <p class="text-neutral-500 text-sm">
            {hero.reassurance}
          </p>
        )}
      </div>

      <!-- Portrait — 5 cols -->
      <div class="hidden lg:flex justify-center lg:col-span-5">
        <div class="relative">
          <!-- Subtle gold accent ring behind -->
          <div class="absolute -inset-3 rounded-2xl border border-accent-500/20" aria-hidden="true"></div>
          <div class="absolute -inset-6 rounded-3xl border border-accent-500/10" aria-hidden="true"></div>
          <div class="w-80 h-[26rem] rounded-2xl overflow-hidden shadow-[0_25px_60px_-15px_rgba(0,0,0,0.5)]">
            <picture>
              <source srcset="/images/hero-portrait.webp" type="image/webp" />
              <img
                src="/images/hero-portrait.jpg"
                alt="Angelo Grossi, coach en prise de parole en public"
                width="320"
                height="416"
                class="w-full h-full object-cover object-top"
                loading="eager"
                fetchpriority="high"
              />
            </picture>
          </div>
          <!-- Warm glow beneath photo -->
          <div class="absolute -bottom-8 left-1/2 -translate-x-1/2 w-48 h-16 bg-accent-500 rounded-full blur-[40px] opacity-15" aria-hidden="true"></div>
        </div>
      </div>
    </div>
  </div>
</section>
