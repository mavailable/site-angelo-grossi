---
/**
 * Méthode H2S — Ambiance théâtrale, fond secondary-950
 */
import SectionEyebrow from '@components/ui/SectionEyebrow.astro';

const steps = [
  {
    letter: 'H',
    label: 'Happy',
    text: 'Être heureux d\'être là et assumer sa parole. Quand vous montez sur scène avec envie plutôt qu\'avec peur, tout change.',
  },
  {
    letter: 'H',
    label: 'Healthy',
    text: 'Être disponible ici et maintenant. Lâcher le contrôle, accueillir l\'imprévu, être pleinement présent face à votre audience.',
  },
  {
    letter: 'S',
    label: 'Sexy',
    text: 'Ouvert, vivant, humainement engageant. Pas une question d\'apparence, mais d\'énergie : celle qui donne envie de vous écouter.',
  },
];
---

<section id="methode" class="relative bg-secondary-950 py-20 md:py-28 overflow-hidden">
  <!-- Subtle warm glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-secondary-800 rounded-full blur-[200px] opacity-30" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <SectionEyebrow text="Mon approche" variant="light" />
      <h2 class="font-heading font-bold text-white text-3xl md:text-4xl leading-tight mb-5">
        La méthode H2S
      </h2>
      <p class="text-neutral-300 leading-relaxed">
        La perfection rassure l'orateur. L'incarnation embarque l'auditoire. Pour convaincre, il ne suffit pas de maîtriser son discours — il faut l'incarner.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-secondary-800/30 max-w-4xl mx-auto">
      {steps.map((step) => (
        <div class="bg-secondary-950 p-8 md:p-10 text-center group">
          <!-- Big letter as design element -->
          <span class="block font-heading font-bold text-6xl md:text-7xl text-accent-500/20 group-hover:text-accent-500/40 transition-colors leading-none mb-2" aria-hidden="true">
            {step.letter}
          </span>
          <h3 class="font-heading font-semibold text-accent-300 text-xl mb-4">{step.label}</h3>
          <p class="text-neutral-400 text-sm leading-relaxed">{step.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
