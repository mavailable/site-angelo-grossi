---
export const prerender = true;
/**
 * Dashboard privé — Angelo Grossi
 * URL secrète, non indexée, non dans le sitemap
 */
import BaseLayout from '@layouts/BaseLayout.astro';

const KS = '/keystatic/branch/master';
---

<BaseLayout
  title="Espace privé — Angelo"
  description="Gérez votre site et consultez vos statistiques."
  noindex={true}
>

<div class="min-h-screen bg-neutral-50">

  <!-- Sticky Tab Navigation -->
  <nav class="sticky top-0 z-40 bg-white/90 backdrop-blur-md border-b border-neutral-200">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 flex items-center justify-between h-14">
      <div class="flex items-center gap-1">
        <button class="tab-btn text-sm font-medium px-4 py-2 rounded-lg transition-colors text-primary-700 bg-primary-50" data-index="0">
          Modifier le site
        </button>
        <button class="tab-btn text-sm font-medium px-4 py-2 rounded-lg transition-colors text-neutral-500" data-index="1">
          Statistiques
        </button>
      </div>
      <span class="hidden sm:block text-xs text-neutral-400 font-medium">Angelo Grossi</span>
    </div>
  </nav>

  <!-- Swipeable Panels -->
  <div id="panels" class="flex overflow-x-auto snap-x snap-mandatory" style="-ms-overflow-style:none; scrollbar-width:none;">

    <!-- ═══ Panel 1 — Modifier le site ═══ -->
    <section class="tab-panel min-w-full snap-start snap-always shrink-0">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">

        <!-- Header -->
        <div class="mb-8">
          <h1 class="font-heading font-bold text-primary-950 text-2xl md:text-3xl mb-3">Modifier votre site</h1>
          <p class="text-neutral-600 leading-relaxed max-w-2xl">
            Vous pouvez modifier tous les textes et contenus de votre site via l'éditeur Keystatic.
            Les modifications sont enregistrées instantanément et le site se met à jour automatiquement.
          </p>
          <div class="mt-4 flex flex-col sm:flex-row gap-3">
            <span class="inline-flex items-center gap-2 text-sm text-neutral-500">
              <span class="w-6 h-6 rounded-full bg-accent-100 text-accent-700 flex items-center justify-center text-xs font-bold">1</span>
              Cliquez sur une rubrique
            </span>
            <span class="inline-flex items-center gap-2 text-sm text-neutral-500">
              <span class="w-6 h-6 rounded-full bg-accent-100 text-accent-700 flex items-center justify-center text-xs font-bold">2</span>
              Modifiez les textes
            </span>
            <span class="inline-flex items-center gap-2 text-sm text-neutral-500">
              <span class="w-6 h-6 rounded-full bg-accent-100 text-accent-700 flex items-center justify-center text-xs font-bold">3</span>
              Cliquez sur Save
            </span>
          </div>
          <div class="mt-6">
            <a href={`${KS}`} target="_blank" rel="noopener noreferrer"
               class="inline-flex items-center gap-2 bg-accent-500 text-primary-950 font-semibold px-5 py-2.5 rounded-lg hover:bg-accent-400 transition-colors text-sm min-h-[44px]">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
              Ouvrir l'éditeur Keystatic
            </a>
          </div>
        </div>

        <!-- Collections -->
        <div class="mb-8">
          <div class="flex items-center gap-3 mb-4">
            <h2 class="font-heading font-semibold text-primary-950 text-lg">Contenus multiples</h2>
            <span class="text-xs bg-accent-100 text-accent-800 px-2.5 py-0.5 rounded-full font-medium">Ajout & suppression possibles</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">

            <!-- Services -->
            <a href={`${KS}/collection/services`} target="_blank" rel="noopener noreferrer"
               class="group block bg-white rounded-xl border border-neutral-200 p-5 hover:border-accent-300 hover:shadow-sm transition-all">
              <div class="flex items-start justify-between mb-3">
                <div class="w-10 h-10 bg-primary-50 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
                </div>
                <span class="text-xs font-semibold bg-primary-100 text-primary-700 px-2 py-0.5 rounded-full">4 entrées</span>
              </div>
              <h3 class="font-heading font-semibold text-primary-950 group-hover:text-accent-700 transition-colors mb-1">Services</h3>
              <div class="flex flex-wrap gap-1">
                <span class="text-xs text-neutral-400">Titre</span>
                <span class="text-xs text-neutral-300">·</span>
                <span class="text-xs text-neutral-400">Description</span>
                <span class="text-xs text-neutral-300">·</span>
                <span class="text-xs text-neutral-400">Ordre</span>
              </div>
            </a>

            <!-- Témoignages -->
            <a href={`${KS}/collection/testimonials`} target="_blank" rel="noopener noreferrer"
               class="group block bg-white rounded-xl border border-neutral-200 p-5 hover:border-accent-300 hover:shadow-sm transition-all">
              <div class="flex items-start justify-between mb-3">
                <div class="w-10 h-10 bg-primary-50 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/></svg>
                </div>
                <span class="text-xs font-semibold bg-primary-100 text-primary-700 px-2 py-0.5 rounded-full">3 entrées</span>
              </div>
              <h3 class="font-heading font-semibold text-primary-950 group-hover:text-accent-700 transition-colors mb-1">Témoignages</h3>
              <div class="flex flex-wrap gap-1">
                <span class="text-xs text-neutral-400">Nom</span>
                <span class="text-xs text-neutral-300">·</span>
                <span class="text-xs text-neutral-400">Fonction</span>
                <span class="text-xs text-neutral-300">·</span>
                <span class="text-xs text-neutral-400">Citation</span>
              </div>
            </a>

            <!-- FAQ -->
            <a href={`${KS}/collection/faq`} target="_blank" rel="noopener noreferrer"
               class="group block bg-white rounded-xl border border-neutral-200 p-5 hover:border-accent-300 hover:shadow-sm transition-all">
              <div class="flex items-start justify-between mb-3">
                <div class="w-10 h-10 bg-primary-50 rounded-lg flex items-center justify-center">
                  <svg class="w-5 h-5 text-primary-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z"/></svg>
                </div>
                <span class="text-xs font-semibold bg-primary-100 text-primary-700 px-2 py-0.5 rounded-full">5 entrées</span>
              </div>
              <h3 class="font-heading font-semibold text-primary-950 group-hover:text-accent-700 transition-colors mb-1">FAQ</h3>
              <div class="flex flex-wrap gap-1">
                <span class="text-xs text-neutral-400">Question</span>
                <span class="text-xs text-neutral-300">·</span>
                <span class="text-xs text-neutral-400">Réponse</span>
                <span class="text-xs text-neutral-300">·</span>
                <span class="text-xs text-neutral-400">Ordre</span>
              </div>
            </a>

          </div>
        </div>

        <!-- Sections du site (dans l'ordre de la page) -->
        <div class="mb-8">
          <div class="flex items-center gap-3 mb-4">
            <h2 class="font-heading font-semibold text-primary-950 text-lg">Sections du site</h2>
            <span class="text-xs bg-neutral-100 text-neutral-600 px-2.5 py-0.5 rounded-full font-medium">Titres, textes, boutons</span>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">

            <!-- Infos générales -->
            <a href={`${KS}/singleton/siteInfo`} target="_blank" rel="noopener noreferrer"
               class="group flex items-center gap-4 bg-white rounded-xl border border-neutral-200 p-4 hover:border-accent-300 hover:shadow-sm transition-all">
              <div class="w-10 h-10 bg-neutral-50 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.25 11.25l.041-.02a.75.75 0 011.063.852l-.708 2.836a.75.75 0 001.063.853l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/></svg>
              </div>
              <div>
                <h3 class="font-heading font-semibold text-primary-950 text-sm group-hover:text-accent-700 transition-colors">Informations générales</h3>
                <p class="text-xs text-neutral-400">Nom, téléphone, email, LinkedIn, URL</p>
              </div>
            </a>

            <!-- Hero -->
            <a href={`${KS}/singleton/hero`} target="_blank" rel="noopener noreferrer"
               class="group flex items-center gap-4 bg-white rounded-xl border border-neutral-200 p-4 hover:border-accent-300 hover:shadow-sm transition-all">
              <div class="w-10 h-10 bg-neutral-50 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>
              </div>
              <div>
                <h3 class="font-heading font-semibold text-primary-950 text-sm group-hover:text-accent-700 transition-colors">Section Hero</h3>
                <p class="text-xs text-neutral-400">Titre principal, sous-titre, boutons, réassurance</p>
              </div>
            </a>

            <!-- Titres des sections -->
            <a href={`${KS}/singleton/sections`} target="_blank" rel="noopener noreferrer"
               class="group flex items-center gap-4 bg-white rounded-xl border border-neutral-200 p-4 hover:border-accent-300 hover:shadow-sm transition-all">
              <div class="w-10 h-10 bg-neutral-50 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25H12"/></svg>
              </div>
              <div>
                <h3 class="font-heading font-semibold text-primary-950 text-sm group-hover:text-accent-700 transition-colors">Titres et textes des sections</h3>
                <p class="text-xs text-neutral-400">Services, Méthode H2S, Témoignages, FAQ, Pied de page</p>
              </div>
            </a>

            <!-- À propos -->
            <a href={`${KS}/singleton/about`} target="_blank" rel="noopener noreferrer"
               class="group flex items-center gap-4 bg-white rounded-xl border border-neutral-200 p-4 hover:border-accent-300 hover:shadow-sm transition-all">
              <div class="w-10 h-10 bg-neutral-50 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"/></svg>
              </div>
              <div>
                <h3 class="font-heading font-semibold text-primary-950 text-sm group-hover:text-accent-700 transition-colors">Section À propos</h3>
                <p class="text-xs text-neutral-400">Surtitre, titre, paragraphes de présentation</p>
              </div>
            </a>

            <!-- Contact -->
            <a href={`${KS}/singleton/contact`} target="_blank" rel="noopener noreferrer"
               class="group flex items-center gap-4 bg-white rounded-xl border border-neutral-200 p-4 hover:border-accent-300 hover:shadow-sm transition-all">
              <div class="w-10 h-10 bg-neutral-50 rounded-lg flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/></svg>
              </div>
              <div>
                <h3 class="font-heading font-semibold text-primary-950 text-sm group-hover:text-accent-700 transition-colors">Section Contact</h3>
                <p class="text-xs text-neutral-400">Titres, encart RDV, bouton Calendly, RGPD</p>
              </div>
            </a>

          </div>
        </div>

        <!-- Conseils -->
        <div class="bg-accent-50 border border-accent-200/50 rounded-xl p-5">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-accent-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"/></svg>
            <div class="text-sm text-neutral-700">
              <p class="font-semibold text-primary-950 mb-1">Conseils</p>
              <ul class="space-y-1 text-neutral-600">
                <li>Cliquez toujours sur <strong>Save</strong> après chaque modification</li>
                <li>Si vous faites une erreur, les versions précédentes sont sauvegardées</li>
                <li>Besoin d'aide ? Contactez votre webmaster ci-dessous</li>
              </ul>
            </div>
          </div>
        </div>

      </div>
    </section>

    <!-- ═══ Panel 2 — Statistiques ═══ -->
    <section class="tab-panel min-w-full snap-start snap-always shrink-0">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 py-8">

        <div class="mb-6">
          <h2 class="font-heading font-bold text-primary-950 text-2xl md:text-3xl mb-2">Statistiques du site</h2>
          <p class="text-neutral-600">Consultez les visites et la fréquentation de votre site en temps réel.</p>
        </div>

        <!-- Desktop : iframe Umami -->
        <div class="hidden md:block bg-white rounded-xl border border-neutral-200 overflow-hidden">
          <div id="umami-container" class="w-full" style="height:750px;">
            <iframe src="https://cloud.umami.is/share/NTGvxb2enRcpfjDM" class="w-full h-full border-0" title="Statistiques du site Angelo Grossi"></iframe>
          </div>
        </div>

        <!-- Mobile : lien vers Umami -->
        <div class="md:hidden">
          <div class="bg-white rounded-xl border border-neutral-200 p-6 text-center">
            <svg class="w-12 h-12 mx-auto mb-3 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z"/></svg>
            <h3 class="font-heading font-semibold text-primary-950 mb-2">Vos statistiques</h3>
            <p class="text-sm text-neutral-500 mb-4">Consultez les visites de votre site sur Umami Analytics</p>
            <a href="https://cloud.umami.is/share/NTGvxb2enRcpfjDM" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-accent-500 text-primary-950 font-semibold px-5 py-2.5 rounded-lg hover:bg-accent-400 transition-colors min-h-[44px]">
              Voir les statistiques
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </a>
          </div>
        </div>

      </div>
    </section>

  </div>

  <!-- Footer contact webmaster -->
  <footer class="border-t border-neutral-200 bg-white py-4">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-sm text-neutral-500">
        Besoin d'aide ?
        <a href="mailto:marc@marc-muller.com" class="text-accent-700 hover:underline font-medium">marc@marc-muller.com</a>
      </p>
    </div>
  </footer>

</div>

<style is:inline>
  #panels { -ms-overflow-style: none; }
  #panels::-webkit-scrollbar { display: none; }
</style>

<script is:inline>
  const panels = document.getElementById('panels');
  const tabs = document.querySelectorAll('.tab-btn');
  const sections = panels.querySelectorAll('.tab-panel');

  function activateTab(index) {
    tabs.forEach((b, i) => {
      if (i === index) {
        b.classList.remove('text-neutral-500');
        b.classList.add('text-primary-700', 'bg-primary-50');
      } else {
        b.classList.remove('text-primary-700', 'bg-primary-50');
        b.classList.add('text-neutral-500');
      }
    });
  }

  tabs.forEach((btn, i) => {
    btn.addEventListener('click', () => {
      sections[i].scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
      activateTab(i);
    });
  });

  let scrollTimeout;
  panels.addEventListener('scroll', () => {
    clearTimeout(scrollTimeout);
    scrollTimeout = setTimeout(() => {
      const index = Math.round(panels.scrollLeft / panels.offsetWidth);
      activateTab(index);
    }, 50);
  }, { passive: true });
</script>

</BaseLayout>
