---
export const prerender = true;
/**
 * Dashboard personas — Angelo Grossi
 * 20 profils simulés + améliorations proposées
 * URL privée, non indexée
 */
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Qui pourrait visiter votre site ? — Angelo Grossi"
  description="20 profils de visiteurs simulés avec leurs parcours et recommandations."
  noindex={true}
>

<div class="min-h-screen bg-neutral-50">

  <!-- Hero compact -->
  <div class="bg-primary-800 py-8 md:py-10">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <a href="/aide-027223c3" class="inline-flex items-center gap-1.5 text-sm text-neutral-300 hover:text-white transition-colors mb-4">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Retour à l'espace privé
      </a>
      <h1 class="font-heading font-bold text-white text-2xl md:text-3xl mb-2">Qui pourrait visiter votre site ?</h1>
      <p class="text-neutral-300 max-w-2xl leading-relaxed">
        20 profils fictifs générés par IA pour simuler des visites sur votre site. Chacun arrive par un chemin différent (Google, réseaux sociaux, bouche-à-oreille, ChatGPT...) et réagit selon ses besoins.
      </p>
    </div>
  </div>

  <!-- Tab bar sticky -->
  <nav class="sticky top-0 z-40 bg-white/95 backdrop-blur border-b border-neutral-200" id="tab-bar">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 flex items-center gap-2 h-12 text-sm">
      <button data-tab="0" class="tab-btn px-5 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-primary-700 bg-primary-50">
        Visiteurs <span class="ml-1 text-xs text-primary-400">20</span>
      </button>
      <button data-tab="1" class="tab-btn px-5 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">
        Améliorations <span class="ml-1 text-xs text-neutral-400">10</span>
      </button>
    </div>
  </nav>

