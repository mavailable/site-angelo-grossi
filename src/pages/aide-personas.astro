        <div class="mb-10">
          <div class="flex items-center gap-2 mb-4">
            <div class="w-2.5 h-2.5 rounded-full bg-green-500"></div>
            <h2 class="font-heading font-semibold text-primary-950 text-lg">Ceux qui vous contactent</h2>
