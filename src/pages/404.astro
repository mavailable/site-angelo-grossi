---
export const prerender = true;
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
---

<BaseLayout
  title="Page introuvable — Angelo Grossi"
  description="Cette page n'existe pas. Retournez à l'accueil pour découvrir les services de coaching en prise de parole."
  noindex={true}
>
  <Header slot="header" />

  <section class="min-h-[60vh] flex items-center justify-center px-4 sm:px-6">
    <div class="text-center max-w-lg">
      <p class="text-7xl font-heading font-bold text-accent-500 mb-4" aria-hidden="true">404</p>
      <h1 class="text-3xl font-heading font-bold text-primary-950 mb-4">
        Cette page n'existe pas
      </h1>
      <p class="text-lg text-neutral-600 mb-8 leading-relaxed">
        Comme en improvisation, parfois on se retrouve en territoire inconnu.
        Pas de panique — revenons à l'essentiel.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/"
           class="inline-flex items-center justify-center bg-accent-500 text-primary-950 font-semibold px-6 py-3 rounded-lg hover:bg-accent-400 transition-colors min-h-[44px]">
          Retour à l'accueil
        </a>
        <a href="#contact"
           class="inline-flex items-center justify-center border-2 border-primary-950 text-primary-950 font-semibold px-6 py-3 rounded-lg hover:bg-primary-950 hover:text-white transition-colors min-h-[44px]">
          Me contacter
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />

  <!-- Track 404 errors -->
  <script>
    if (typeof umami !== 'undefined') umami.track('404-error', { path: window.location.pathname });
  </script>
</BaseLayout>
